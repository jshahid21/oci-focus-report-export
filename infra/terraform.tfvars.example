# Copy to terraform.tfvars and fill in your values.
# See README.md → Prerequisites & OCI Authentication before running tofu apply.

region       = "us-ashburn-1"
tenancy_ocid = "ocid1.tenancy.oc1..aaaa..."

# =============================================================================
# COMPARTMENTS
# Default compartment for all resources. Override per resource type if needed.
# =============================================================================
create_compartment      = false
existing_compartment_id = "ocid1.compartment.oc1..aaaa..."

# Optional: place resources in different compartments (leave empty to use existing_compartment_id)
# compute_compartment_id = "ocid1.compartment.oc1..aaaa..."   # sync VM + bastion VM
# network_compartment_id = "ocid1.compartment.oc1..aaaa..."   # VCN, gateways, subnets
# vault_compartment_id   = "ocid1.compartment.oc1..aaaa..."   # Vault, KMS key, secrets

# =============================================================================
# NETWORKING
# Option A — Use existing VCN and private subnet (recommended for enterprise)
# Option B — Create everything new (set create_* = true, clear existing_* ids)
# =============================================================================

# VCN
create_vcn      = false
existing_vcn_id = "ocid1.vcn.oc1..aaaa..."

# Private subnet (sync VM always placed here — no public IP ever assigned)
create_subnet      = false
existing_subnet_id = "ocid1.subnet.oc1..aaaa..."

# NAT Gateway — required for sync VM → AWS S3 (internet egress)
create_nat_gateway      = false
existing_nat_gateway_id = "ocid1.natgateway.oc1..aaaa..."

# Service Gateway — required for sync VM → OCI Object Storage / bling namespace
create_service_gateway      = false
existing_service_gateway_id = "ocid1.servicegateway.oc1..aaaa..."

# =============================================================================
# SSH ACCESS TO THE PRIVATE SYNC VM
# Optional — not required if sync runs unattended.
# =============================================================================

# OCI Bastion Service — managed, keyless SSH; no extra VM needed
# Enables the Bastion plugin on the sync VM via Oracle Cloud Agent.
use_bastion_service           = false
# bastion_service_allowed_cidrs = ["203.0.113.10/32"]   # restrict to your IP(s)

# Optional SSH public key — enables port-forwarding Bastion sessions as a
# reliable fallback if Managed SSH (Cloud Agent) is slow to start.
# ssh_public_key_path = "~/.ssh/id_rsa.pub"

# Temporary bastion VM for SSH debugging — set false and tofu apply to remove when done
create_bastion_vm          = true
existing_bastion_subnet_id = "ocid1.subnet.oc1.iad.aaaaaaaarcjzthn72wml7h736hdfwecnloypk5zjlkn6fnzbdxczpjz3amnq"   # existing public subnet

# =============================================================================
# VAULT & SECRETS
# =============================================================================
create_vault      = false
existing_vault_id = "ocid1.vault.oc1..aaaa..."

create_key      = false
existing_key_id = "ocid1.key.oc1..aaaa..."

create_aws_secrets                = false
existing_aws_access_key_secret_id = "ocid1.vaultsecret.oc1..aaaa..."
existing_aws_secret_key_secret_id = "ocid1.vaultsecret.oc1..aaaa..."

# Only needed when create_aws_secrets = true
# aws_access_key = "AKIA..."
# aws_secret_key = "your-secret-here"

# =============================================================================
# AWS DESTINATION
# =============================================================================
aws_s3_bucket_name = "my-oci-cost-reports"
aws_s3_prefix      = "oci-sync"
aws_region         = "us-east-2"

# =============================================================================
# MONITORING
# =============================================================================
enable_monitoring   = true
alert_email_address = "you@example.com"

# =============================================================================
# COMPUTE (optional overrides)
# =============================================================================
# instance_shape     = "VM.Standard.E4.Flex"   # or A1.Flex for free tier ARM
# instance_ocpus     = 1
# instance_memory_gb = 4
# opc_password       = ""                       # Serial Console access only
